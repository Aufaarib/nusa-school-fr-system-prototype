# ─────────────────────────────────────────────
#  Face Recognition System - Environment Config
# ─────────────────────────────────────────────

# Server port (default: 3000)
PORT=3100

# ── External API ─────────────────────────────
NEXT_PUBLIC_BASE_URL="https://api-staging-nusa.nuncorp.id/api/v1/"
NEXT_PUBLIC_STORAGE_URL="https://api-staging-nusa.nuncorp.id/be2"

# ── Email Notifications ───────────────────────
# Gmail account to send notifications FROM
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password-here

# Email address to RECEIVE notifications
NOTIFY_EMAIL=admin@example.com
